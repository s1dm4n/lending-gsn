<section class="swiper-main gutter gt fade-in">
  <div class="swiper-wrapper">
    {% for slide in slides %}
      {% if loop.index < 10 %}
        {% set slideNumber = "0" ~ loop.index %}
      {% else %}
        {% set slideNumber = loop.index %}
      {% endif %}
      <div class="swiper-slide">
        <div class="card">
          <picture>
            <source srcset="img/slide-{{ slideNumber }}.avif 1x, img/slide-{{ slideNumber }}@2x.avif 2x" type="image/avif"/>
            <source srcset="img/slide-{{ slideNumber }}.webp 1x, img/slide-{{ slideNumber }}@2x.webp 2x" type="image/webp"/>
            <img
              src="img/slide-{{ slideNumber }}.jpg"
              srcset="img/slide-{{ slideNumber }}.jpg 1x, img/slide-{{ slideNumber }}@2x.jpg 2x"
              alt="{{slide.alt}}"
              loading="lazy"/>
          </picture>
        </div>
      </div>
    {% endfor %}
  </div>
  <div class="swiper-main-pagination"></div>
